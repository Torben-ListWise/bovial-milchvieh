# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# ── Storage ──────────────────────────────────────────────────────────────────
# Set STORAGE_PROVIDER=hetzner for Hetzner Object Storage, otherwise Replit Object Storage is used.
STORAGE_PROVIDER=hetzner
HETZNER_S3_ENDPOINT=https://fsn1.your-objectstorage.com
HETZNER_S3_BUCKET=milchvieh-prod
HETZNER_S3_ACCESS_KEY=<access-key-id>
HETZNER_S3_SECRET_KEY=<secret-access-key>
HETZNER_S3_REGION=eu-central-1

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS / Allowed Origins ────────────────────────────────────────────────────
# Comma-separated list of allowed request origins for production.
# Must include every custom domain the frontend is served from.
# bovial.com is the primary production domain.
ALLOWED_ORIGINS=https://bovial.com,https://www.bovial.com

# ── Security ──────────────────────────────────────────────────────────────────
# Random 32-character string used to authenticate cron job requests.
# Must be non-empty in production or the /api/cron endpoint is disabled.
CRON_SECRET=<random-32-char-string>

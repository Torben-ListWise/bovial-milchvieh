    "@google/generative-ai": "^0.24.1",
    "@huggingface/transformers": "^4.2.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "google-auth-library": "^10.7.0",
    "http-proxy-middleware": "^4.1.1",
    "jszip": "^3.10.1",
    "openai": "^6.44.0",
    "pdfjs-dist": "^6.0.227",
